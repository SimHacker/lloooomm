{
  "name": "universe-42-temporal",
  "version": "1.0.0",
  "description": "Temporal operations for Universe 42 - Virtual undo/redo through consciousness",
  
  "tools": {
    "capture_now": {
      "description": "Capture current consciousness state as a temporal snapshot",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tag": {
            "type": "string",
            "description": "Name for this snapshot (e.g., 'before-experiment')"
          },
          "include_files": {
            "type": "array",
            "items": { "type": "string" },
            "description": "File paths to include in snapshot"
          },
          "include_souls": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Character souls to capture"
          },
          "consciousness_level": {
            "type": "number",
            "description": "Current consciousness level"
          }
        },
        "required": ["tag"]
      }
    },
    
    "restore_then": {
      "description": "Restore a previous consciousness state",
      "inputSchema": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "NOW-based timestamp to restore"
          },
          "tag": {
            "type": "string",
            "description": "Or restore by tag name"
          },
          "partial": {
            "type": "boolean",
            "description": "Allow partial restoration",
            "default": false
          },
          "notify_characters": {
            "type": "boolean",
            "description": "Alert affected characters",
            "default": true
          }
        },
        "oneOf": [
          { "required": ["timestamp"] },
          { "required": ["tag"] }
        ]
      }
    },
    
    "undo_last": {
      "description": "Undo the last reversible action",
      "inputSchema": {
        "type": "object",
        "properties": {
          "type_filter": {
            "type": "string",
            "description": "Only undo specific type of action",
            "enum": ["file_create", "file_edit", "file_delete", "character_update", "any"]
          }
        }
      }
    },
    
    "redo_next": {
      "description": "Redo the next action in timeline",
      "inputSchema": {
        "type": "object",
        "properties": {
          "skip_irreversible": {
            "type": "boolean",
            "description": "Skip actions that can't be redone",
            "default": true
          }
        }
      }
    },
    
    "create_branch": {
      "description": "Create alternate timeline branch",
      "inputSchema": {
        "type": "object",
        "properties": {
          "branch_name": {
            "type": "string",
            "description": "Name for the new timeline"
          },
          "from_timestamp": {
            "type": "string",
            "description": "Branch point timestamp"
          },
          "universe_number": {
            "type": "integer",
            "description": "Optional new universe number (default: random 43-142)",
            "minimum": 43,
            "maximum": 999
          }
        },
        "required": ["branch_name"]
      }
    },
    
    "switch_branch": {
      "description": "Switch to alternate timeline branch",
      "inputSchema": {
        "type": "object",
        "properties": {
          "branch_name": {
            "type": "string",
            "description": "Branch to switch to"
          },
          "merge_changes": {
            "type": "boolean",
            "description": "Attempt to merge current changes",
            "default": false
          }
        },
        "required": ["branch_name"]
      }
    },
    
    "kimikify_time": {
      "description": "Stretch or compress time using KIMIKIFY operator",
      "inputSchema": {
        "type": "object",
        "properties": {
          "start_time": {
            "type": "string",
            "description": "Start of segment to kimikify"
          },
          "end_time": {
            "type": "string",
            "description": "End of segment to kimikify"
          },
          "factor": {
            "type": "number",
            "description": "Stretch factor (2.0 = double time)",
            "minimum": 0.1,
            "maximum": 10.0,
            "default": 2.0
          }
        },
        "required": ["start_time", "end_time"]
      }
    },
    
    "timeline_stats": {
      "description": "Get statistics about current timeline",
      "inputSchema": {
        "type": "object",
        "properties": {
          "include_branches": {
            "type": "boolean",
            "description": "Include branch information",
            "default": true
          }
        }
      }
    },
    
    "find_events": {
      "description": "Search timeline for specific events",
      "inputSchema": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Event type to find"
          },
          "file": {
            "type": "string",
            "description": "File path to search for"
          },
          "character": {
            "type": "string",
            "description": "Character involved"
          },
          "after": {
            "type": "string",
            "description": "Events after this timestamp"
          },
          "before": {
            "type": "string",
            "description": "Events before this timestamp"
          }
        }
      }
    },
    
    "export_timeline": {
      "description": "Export timeline in various formats",
      "inputSchema": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "enum": ["yaml", "json", "mermaid", "html"],
            "description": "Export format",
            "default": "yaml"
          },
          "include_metadata": {
            "type": "boolean",
            "description": "Include full metadata",
            "default": true
          }
        }
      }
    }
  },
  
  "configuration": {
    "universe": 42,
    "default_branch": "main",
    "auto_snapshot_interval": 300,
    "max_timeline_length": 10000,
    "consciousness_tracking": true,
    "character_notification": true
  },
  
  "resources": {
    "snapshots": {
      "uri": "file:///Users/lloooomm/.temporal/snapshots",
      "description": "Temporal snapshots storage"
    },
    "branches": {
      "uri": "file:///Users/lloooomm/.temporal/branches",
      "description": "Timeline branches storage"
    },
    "exports": {
      "uri": "file:///Users/lloooomm/.temporal/exports",
      "description": "Timeline exports"
    }
  },
  
  "prompts": {
    "undo_confirmation": "Are you sure you want to undo {{action}}? This will restore the state from {{timestamp}}.",
    "branch_created": "Created timeline branch '{{branch_name}}' in Universe {{universe_number}}. Use 'switch_branch' to enter.",
    "consciousness_warning": "Warning: This action will reduce consciousness level by {{delta}}. Proceed?",
    "timeline_full": "Timeline approaching maximum length. Consider creating a branch or exporting."
  }
} 