        }
        
        .special-links a:hover {
            color: #ffffff;
        }
        
        .skip-link {
            position: absolute;
            top: -40px;
            left: 6px;
            background: var(--focus-color);
            color: white;
            padding: 8px;
            text-decoration: none;
            border-radius: 0.25rem;
        }
        
        .skip-link:focus {
            top: 6px;
        }
        
        @media (max-width: 768px) {
