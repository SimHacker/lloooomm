        /* Accessibility-first CSS following Nielsen/Shneiderman principles */
        :root {
            --primary-color: #000000;
            --secondary-color: #000000;
            --accent-color: #f59e0b;
            --text-color: #1f2937;
            --bg-color: #ffffff;
            --border-color: #d1d5db;
            --hover-color: #eff6ff;
            --focus-color: #1d4ed8;
            --link-color: #0066cc;
            --link-visited: #551a8b;
            --link-hover: #004499;
        }
        
        * {
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            line-height: 1.6;
            color: var(--text-color);
            background-color: var(--bg-color);
            margin: 0;
            padding: 0;
        }
        
        .container {
            margin: 0 auto;
            padding: 1rem;
        }
        
        header {
            text-align: center;
            margin-bottom: 1rem;
            padding: 0.5rem 0;
            border-bottom: 2px solid var(--border-color);
        }
        
        h1 {
            font-size: 3rem;
            margin-bottom: 0.5rem;
            color: var(--primary-color);
        }
        
        .subtitle {
            font-size: 1.25rem;
            color: #6b7280;
            margin-bottom: 0.5rem;
        }
        
        .nav-toc {
